`timescale 100 ps/100 ps
module bit4adder(
	a0,
	a1,
	a2,
	a3,
	b0,
	b1,
	b2,
	b3,
	cin,
	s0,
	s1,
	s2,
	s3,
	cout
);
input a0;
input a1;
input a2;
input a3;
input b0;
input b1;
input b2;
input b3;
input cin;
output s0;
output s1;
output s2;
output s3;
output cout;
wire GND;
wire VCC;
wire a0;
wire a0_d;
wire a1;
wire a1_d;
wire a2;
wire a2_d;
wire a3;
wire a3_d;
wire b0;
wire b0_d;
wire b1;
wire b1_d;
wire b2;
wire b2_d;
wire b3;
wire b3_d;
